{
  "name": "otel",
  "version": "0.5.0",
  "description": "OpenTelemetry per-request metrics: request shape on the way in; latency, status class, and token usage (from the host's _response signal) on the way out",
  "hooks": [
    {"name": "run_before_request", "priority": 50},
    {"name": "run_after_response", "priority": 50},
    {"name": "run_on_http_request", "priority": 50}
  ],
  "permissions": [
    {"name": "env.emit_metric", "description": "Emit OTel-compatible metrics"},
    {"name": "env.log", "description": "Diagnostic logging"},
    {"name": "env.serve_http", "description": "Serve a status/info page under /_torana/plugin/otel/"}
  ]
}
