{
  "name": "otel-metrics",
  "version": "0.3.0",
  "description": "Exports Torana metrics via OpenTelemetry",
  "hooks": [{"name": "on_chat_request", "priority": 300}],
  "permissions": [
    {"name": "env.cache_get", "description": "Read token counters"},
    {"name": "env.log", "description": "Diagnostic logging"}
  ]
}
