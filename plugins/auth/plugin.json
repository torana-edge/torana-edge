{
  "name": "auth",
  "version": "0.1.0",
  "description": "Enterprise Gateway auth normalization",
  "hooks": [
    {
      "name": "run_before_request",
      "priority": 100
    }
  ],
  "permissions": [
    {
      "name": "env.host_call.verify_virtual_key",
      "description": "verify torana virtual keys"
    },
    {
      "name": "env.request_headers",
      "description": "read allowlisted auth headers (Authorization, X-Api-Key, X-Torana-*)"
    }
  ]
}
