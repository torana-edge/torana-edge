{
  "port": 8080,
  "providers": {
    "deepseek": {
      "url": "https://api.deepseek.com",
      "format": "openai"
    },
    "deepseek-anthropic": {
      "url": "https://api.deepseek.com/anthropic",
      "format": "anthropic"
    }
  },
  "plugins": {
    "dir": "./plugins",
    "_comment": "Dogfood the safe deterministic policy. Run one compactor only, after intent; unmatched tools and failures stay exact.",
    "order": ["schema_translator", "intent", "keyword_compactor"],
    "config": {
      "keyword_compactor": {
        "tool_policies": [
          {"match": "read*", "mode": "source", "rerun": "Read the file again to recover exact current contents."},
          {"match": "view*", "mode": "source", "rerun": "View the file again to recover exact current contents."},
          {"match": "web_search", "mode": "deterministic", "first_pass": true, "rerun": "Repeat the search to recover every result."},
          {"match": "grep*", "mode": "keyword"}
        ]
      }
    }
  },
  "offload": {
    "enabled": false,
    "provider": "deepseek",
    "model": "deepseek-v4-flash"
  },
  "limits": {
    "concurrency": 10,
    "rpm": 100
  }
}
